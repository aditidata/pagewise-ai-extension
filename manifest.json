{
  "manifest_version": 3,
  "name": "PageWise AI",
  "version": "3.0",
  "description": "AI PDF reader with working RAG chat.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://cdn.jsdelivr.net/*",
    "https://huggingface.co/*",
    "https://*.huggingface.co/*",
    "https://hf.co/*",
    "https://*.hf.co/*",
    "https://api.groq.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"] }],
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.html", "viewer.js", "styles.css",
        "rag.js", "rag-worker.js",
        "lib/*", "pdfjs/*", "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' https://cdn.jsdelivr.net https://huggingface.co https://*.huggingface.co https://hf.co https://*.hf.co https://api.groq.com data: blob: file:;"
  }
}
